{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Narrative Core Entry Schema",
  "description": "Schema for origin_story, breakthrough, builder_profile, shadow, and star_trek_spec entries",
  "type": "object",
  "required": ["id", "entry_type", "domain", "shift_arc", "council_voices", "shadow_check", "governance"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ac-[0-9]+-[a-f0-9]+$"
    },
    "entry_type": {
      "type": "string",
      "enum": ["origin_story", "breakthrough", "builder_profile", "shadow", "star_trek_spec"]
    },
    "domain": {
      "type": "string",
      "enum": ["energy", "food", "water", "health", "education", "shelter", "environment", "security", "governance", "economy", "resources", "space", "consciousness", "longevity", "transportation", "communication", "computation-intelligence", "co-evolutionary-intelligence", "community", "human-capability", "future-vision"]
    },
    "shift_arc": {
      "type": "object",
      "required": ["scarcity_frame", "encounter", "reframe", "proof", "invitation"],
      "properties": {
        "scarcity_frame": { "type": "object" },
        "encounter": { "type": "object" },
        "reframe": { "type": "object" },
        "proof": { "type": "object" },
        "invitation": { "type": "object" }
      }
    },
    "council_voices": {
      "type": "object",
      "required": ["oracle", "critic", "sensei", "builder", "witness"],
      "properties": {
        "oracle": { "type": "object" },
        "critic": { "type": "object" },
        "sensei": { "type": "object" },
        "builder": { "type": "object" },
        "witness": { "type": "object" }
      }
    },
    "shadow_check": {
      "type": "object",
      "required": ["distortion_risks", "who_gets_left_behind", "transition_pain", "falsifiability_edge"],
      "properties": {
        "distortion_risks": { "type": "array", "items": { "type": "string" } },
        "who_gets_left_behind": { "type": "string" },
        "transition_pain": { "type": "string" },
        "what_this_is_not": { "type": ["string", "array"] },
        "falsifiability_edge": { "type": "string" }
      }
    },
    "6d_position": {
      "type": "object",
      "properties": {
        "digitized": { "type": "object" },
        "deceptive": { "type": "object" },
        "disruptive": { "type": "object" },
        "demonetized": { "type": "object" },
        "dematerialized": { "type": "object" },
        "democratized": { "type": "object" },
        "current_phase": { "type": "string" },
        "estimated_timeline_to_next": { "type": "string" }
      }
    },
    "regenerative_frame": {
      "type": "object",
      "properties": {
        "classification": { "type": "string", "enum": ["extractive", "regenerative", "transitional"] },
        "circular_design": { "type": "string" },
        "net_impact": { "type": "string" }
      }
    },
    "connections": {
      "type": "object",
      "properties": {
        "related_entries": { "type": "array", "items": { "type": "string" } },
        "supports": { "type": "array", "items": { "type": "string" } },
        "challenges": { "type": "array", "items": { "type": "string" } },
        "builds_toward": { "type": "string" }
      }
    },
    "governance": {
      "type": "object",
      "required": ["source_type", "evidence_quality", "confidence", "last_verified"],
      "properties": {
        "source_type": { "type": "string", "enum": ["lived-experience", "journalism", "research", "conversation", "synthesis"] },
        "evidence_quality": { "type": "string", "enum": ["anecdotal", "sourced", "peer-reviewed", "meta-analysis"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "last_verified": { "type": "string", "format": "date" },
        "counter_sources": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}