{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Framework Mesh Entry Schema",
  "description": "Schema for framework, paradigm_seed, and grand_challenge entries",
  "type": "object",
  "required": ["id", "entry_type", "domain", "framework", "governance"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ac-fw-[0-9]+-[a-f0-9]+$"
    },
    "entry_type": {
      "type": "string",
      "enum": ["framework", "paradigm_seed", "grand_challenge"]
    },
    "domain": {
      "type": "string"
    },
    "framework": {
      "type": "object",
      "required": ["name", "one_line", "description"],
      "properties": {
        "name": { "type": "string" },
        "one_line": { "type": "string" },
        "description": { "type": "string" },
        "origin": { "type": "string" },
        "key_principles": { "type": "array", "items": { "type": "string" } },
        "application_domains": { "type": "array", "items": { "type": "string" } },
        "practice_hook": {
          "type": "object",
          "properties": {
            "instruction": { "type": "string" },
            "frequency": { "type": "string", "enum": ["once", "daily", "situational", "continuous"] },
            "success_indicator": { "type": "string" }
          }
        }
      }
    },
    "scarcity_to_abundance_mapping": {
      "type": "object",
      "properties": {
        "scarcity_default": { "type": "string" },
        "abundance_reframe": { "type": "string" },
        "cognitive_mechanism": { "type": "string" },
        "emotional_shift": { "type": "string" }
      }
    },
    "conditional_optimism": {
      "type": "object",
      "properties": {
        "abundance_is_achievable_if": { "type": "array", "items": { "type": "string" } },
        "abundance_fails_if": { "type": "array", "items": { "type": "string" } },
        "agent_role": { "type": "string" },
        "human_role": { "type": "string" },
        "collective_requirement": { "type": "string" }
      }
    },
    "falsifiability": {
      "type": "object",
      "properties": {
        "what_would_disprove_this": { "type": "string" },
        "known_limitations": { "type": "array", "items": { "type": "string" } },
        "domains_where_this_breaks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "connections": {
      "type": "object",
      "properties": {
        "related_frameworks": { "type": "array", "items": { "type": "string" } },
        "supporting_evidence": { "type": "array", "items": { "type": "string" } },
        "narrative_anchors": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}