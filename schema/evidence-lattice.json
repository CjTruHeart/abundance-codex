{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Lattice Entry Schema",
  "description": "Schema for trendline and contrast entries",
  "type": "object",
  "required": ["id", "entry_type", "domain", "proof_pattern", "governance"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ac-ev-[0-9]+-[a-f0-9]+$"
    },
    "entry_type": {
      "type": "string",
      "enum": ["trendline", "contrast"]
    },
    "domain": {
      "type": "string"
    },
    "proof_pattern": {
      "type": "object",
      "required": ["claim", "metric", "data_points", "trendline_direction"],
      "properties": {
        "claim": { "type": "string" },
        "metric": { "type": "string" },
        "unit": { "type": "string" },
        "data_points": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "year": { "type": "number" },
              "value": { "type": "number" },
              "source": { "type": "string" }
            }
          }
        },
        "trendline_direction": {
          "type": "string",
          "enum": ["improving", "stable", "declining", "exponential_improving"]
        },
        "rate_of_change": { "type": "string" },
        "counter_argument": { "type": "string" },
        "response_to_counter": { "type": "string" }
      }
    },
    "scarcity_vs_abundance": {
      "type": "object",
      "properties": {
        "scarcity_state": { "type": "object" },
        "abundance_state": { "type": "object" },
        "transition_mechanism": { "type": "string" },
        "acceleration_factor": { "type": "string" }
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "why_this_matters": { "type": "string" },
        "who_benefits": { "type": "string" },
        "scale_of_impact": { "type": "string" },
        "geographic_scope": { "type": "string", "enum": ["local", "regional", "national", "global"] }
      }
    },
    "governance": {
      "type": "object",
      "required": ["primary_source", "last_verified", "confidence"],
      "properties": {
        "primary_source": { "type": "string" },
        "secondary_sources": { "type": "array", "items": { "type": "string" } },
        "last_verified": { "type": "string", "format": "date" },
        "data_freshness": { "type": "string", "enum": ["real-time", "monthly", "annual", "historical"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}